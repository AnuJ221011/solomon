generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  BUYER
  BRAND
  ADMIN
}

enum BrandStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AchievementLevel {
  L1_SPROUT
  L2_RISING
  L3_TRUSTED
  L4_ELITE
  L5_LEGEND
}

enum ProductAvailability {
  ACTIVE
  INACTIVE
  COMING_SOON
}

enum LeadTime {
  ONE_TO_THREE_DAYS
  ONE_TO_TWO_WEEKS
  TWO_TO_FOUR_WEEKS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
  DISPUTED
}

enum ShippingZone {
  DOMESTIC
  SOUTH_ASIA
  SOUTHEAST_ASIA
  MIDDLE_EAST
  EUROPE
  NORTH_AMERICA
  OCEANIA
  REST_OF_WORLD
}

enum ShippingRateType {
  FLAT
  PER_KG
}

enum CreditStatus {
  PENDING
  ACTIVE
  USED
  EXPIRED
}

enum ShareLinkTarget {
  PRODUCT
  COLLECTION
  STOREFRONT
}

enum VariantStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum PayoutSpeed {
  NET_30
  EXPRESS
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  LABEL_ISSUED
  RECEIVED
  REFUNDED
}

enum TeamRole {
  ADMIN
  CUSTOM
}

enum PromotionScope {
  CATALOG
  COLLECTION
}

// ─────────────────────────────────────────────
// USER & PROFILES
// ─────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String?
  name            String
  googleId        String?  @unique
  avatarUrl       String?
  role            Role     @default(BUYER)
  isEmailVerified Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  buyerProfile     BuyerProfile?
  brandProfile     BrandProfile?
  orders           Order[]           @relation("BuyerOrders")
  referralsGiven   BuyerReferral[]   @relation("ReferrerBuyer")
  wallet           Wallet?
  cart             Cart?
  teamMemberships  TeamMember[]      @relation("TeamMemberUser")
  ownedTeamMembers TeamMember[]      @relation("TeamOwnerUser")
  reviews          ProductReview[]
  sentMessages     Message[]         @relation("MessageSender")
  receivedMessages Message[]         @relation("MessageRecipient")

  @@index([email])
  @@index([googleId])
}

model BuyerProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName        String
  countryCode         String
  phone               String?
  preferredCurrency   String    @default("USD")
  // Store type quiz fields
  storeType           String?   // boutique | gift_shop | subscription_box | online_store | pop_up | other
  aesthetic           String?   // minimalist | bohemian | artisan | luxury | contemporary | eclectic
  categoryInterests   String[]  @default([])
  // Business verification
  businessVerified    Boolean   @default(false)
  businessVerifiedAt  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  savedProducts       SavedProduct[]
  savedBrands         SavedBrand[]

  @@index([userId])
}

model BrandProfile {
  id                   String          @id @default(cuid())
  userId               String          @unique
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandName            String
  slug                 String          @unique
  category             String[]
  countryOfOrigin      String          @default("IN")
  gstNumber            String?
  businessRegNumber    String?
  description          String?
  brandStory           String?
  instagramHandle      String?
  websiteUrl           String?
  yearFounded          Int?
  socialLinks          Json?           // { instagram, facebook, twitter, pinterest }
  existingRetailPartners String?
  pickupPincode        String?   // used for Shiprocket rate calculation
  logoUrl              String?
  bannerUrl            String?
  status               BrandStatus     @default(PENDING)
  achievementLevel     AchievementLevel @default(L1_SPROUT)
  isAdminOverride      Boolean         @default(false)
  confirmedOrderCount  Int             @default(0)
  avgRating            Float           @default(0)
  totalGmvInr          Decimal         @default(0) @db.Decimal(15, 2)
  avgDispatchDays      Float           @default(0)
  payoutSpeed          PayoutSpeed     @default(NET_30)
  approvedAt           DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  products             Product[]
  shareLinks           ShareLink[]
  shippingRates        ShippingRate[]
  orders               Order[]         @relation("BrandOrders")
  payouts              Payout[]
  referralsReceived    BuyerReferral[] @relation("ReferredBrand")
  collections          Collection[]
  promotions           Promotion[]
  promotedListings     PromotedListing[]
  crmContacts          CrmContact[]
  shopifyStore         ShopifyStore?

  @@index([slug])
  @@index([status])
  @@index([achievementLevel])
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([sortOrder])
}

model Product {
  id               String              @id @default(cuid())
  brandProfileId   String
  brandProfile     BrandProfile        @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  name             String              @db.VarChar(80)
  slug             String              @unique
  shortDescription String              @db.VarChar(160)
  fullDescription  String?
  wholesalePriceInr Decimal            @db.Decimal(12, 2)
  moq              Int
  leadTime         LeadTime
  weightGrams      Int
  hsTariffCode     String?
  countryOfOrigin  String              @default("IN")
  categories       String[]
  tags             String[]
  availability     ProductAvailability @default(ACTIVE)
  enabledZones     ShippingZone[]
  viewCount        Int                 @default(0)
  orderCount       Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  photos            ProductPhoto[]
  variants          ProductVariant[]
  orderItems        OrderItem[]
  savedBy           SavedProduct[]
  reviews           ProductReview[]
  cartItems         CartItem[]
  collectionItems   CollectionProduct[]
  promotedListings  PromotedListing[]

  @@index([brandProfileId])
  @@index([availability])
}

model ProductPhoto {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  publicId   String
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id                String           @id @default(cuid())
  productId         String
  product           Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku               String           @unique
  priceInr          Decimal          @db.Decimal(12, 2)
  stock             Int              @default(0)
  imageUrl          String?
  status            VariantStatus    @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  attributes        VariantAttribute[]
  orderItems        OrderItem[]
  cartItems         CartItem[]

  @@index([productId])
  @@index([sku])
}

// EAV table — stores attribute key/value pairs per variant (Color/Red, Size/L, etc.)
// New attribute types require no schema change.
model VariantAttribute {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  name      String         // e.g. "Color", "Size", "Material"
  value     String         // e.g. "Red", "L", "Cotton"

  @@index([variantId])
  @@index([name])
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items     CartItem[]
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  cart           Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  quantity       Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // variantId can be null for variant-free products; uniqueness enforced in service layer
  @@index([cartId])
  @@index([variantId])
}

// ─────────────────────────────────────────────
// SHIPPING
// ─────────────────────────────────────────────

model ShippingRate {
  id                   String           @id @default(cuid())
  brandProfileId       String
  brandProfile         BrandProfile     @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  zone                 ShippingZone
  rateType             ShippingRateType
  flatRateInr          Decimal?         @db.Decimal(10, 2)
  perKgRateInr         Decimal?         @db.Decimal(10, 2)
  freeShippingAboveInr Decimal?         @db.Decimal(12, 2)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([brandProfileId, zone])
  @@index([brandProfileId])
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id                   String      @id @default(cuid())
  buyerUserId          String
  buyer                User        @relation("BuyerOrders", fields: [buyerUserId], references: [id])
  brandProfileId       String
  brand                BrandProfile @relation("BrandOrders", fields: [brandProfileId], references: [id])
  status               OrderStatus @default(PENDING)
  subtotalInr          Decimal     @db.Decimal(12, 2)
  shippingCostInr      Decimal     @db.Decimal(10, 2) @default(0)
  commissionRate       Decimal     @db.Decimal(5, 4)  // e.g. 0.1500 = 15%
  commissionInr        Decimal     @db.Decimal(10, 2)
  totalInr             Decimal     @db.Decimal(12, 2)
  buyerCurrency        String
  totalBuyerCurrency   Decimal     @db.Decimal(12, 2)
  fxRateUsed           Decimal     @db.Decimal(10, 6)
  shippingZone         ShippingZone
  isOpeningOrder       Boolean     @default(false)
  isManualOrder        Boolean     @default(false)
  trackingNumber       String?
  trackingCarrier      String?
  paypalOrderId        String?
  paypalCaptureId      String?
  dispatchedAt         DateTime?
  deliveredAt          DateTime?
  shareLinkId          String?
  shareLink            ShareLink?  @relation(fields: [shareLinkId], references: [id])
  notes                String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  items                OrderItem[]
  payout               Payout?
  returns              Return[]
  reviews              ProductReview[]
  messages             Message[]

  @@index([buyerUserId])
  @@index([brandProfileId])
  @@index([status])
  @@index([shareLinkId])
}

model OrderItem {
  id           String          @id @default(cuid())
  orderId      String
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  // Snapshot of the selected variant attributes at order time (for display after variant is changed)
  variantLabel String?         // e.g. "Color: Red / Size: L"
  quantity     Int
  unitPriceInr Decimal         @db.Decimal(12, 2)
  totalInr     Decimal         @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

// ─────────────────────────────────────────────
// RETURNS & DISPUTES
// ─────────────────────────────────────────────

model Return {
  id             String       @id @default(cuid())
  orderId        String
  order          Order        @relation(fields: [orderId], references: [id])
  requestedById  String
  reason         String
  photoUrls      String[]     @default([])
  status         ReturnStatus @default(REQUESTED)
  isOpeningOrder Boolean      @default(false)
  adminNotes     String?
  returnLabelUrl String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([orderId])
  @@index([status])
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model ProductReview {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id])
  reviewerUserId String
  reviewer       User     @relation(fields: [reviewerUserId], references: [id])
  rating         Int
  comment        String?
  brandResponse  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([orderId, productId])
  @@index([productId])
  @@index([reviewerUserId])
}

// ─────────────────────────────────────────────
// COLLECTIONS & PROMOTIONS
// ─────────────────────────────────────────────

model Collection {
  id             String             @id @default(cuid())
  brandProfileId String
  brandProfile   BrandProfile       @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  products       CollectionProduct[]
  promotions     Promotion[]

  @@index([brandProfileId])
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  position     Int        @default(0)

  @@unique([collectionId, productId])
}

model Promotion {
  id              String         @id @default(cuid())
  brandProfileId  String
  brandProfile    BrandProfile   @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  name            String
  discountPercent Int
  scope           PromotionScope
  collectionId    String?
  collection      Collection?    @relation(fields: [collectionId], references: [id])
  startsAt        DateTime
  endsAt          DateTime?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([brandProfileId])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// TEAM MANAGEMENT
// ─────────────────────────────────────────────

model TeamMember {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation("TeamMemberUser", fields: [userId], references: [id])
  ownerUserId      String
  owner            User     @relation("TeamOwnerUser", fields: [ownerUserId], references: [id])
  role             TeamRole @default(CUSTOM)
  canViewPayouts   Boolean  @default(false)
  canViewAnalytics Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@unique([userId, ownerUserId])
  @@index([ownerUserId])
}

// ─────────────────────────────────────────────
// SHARE LINKS
// ─────────────────────────────────────────────

model ShareLink {
  id              String          @id @default(cuid())
  brandProfileId  String
  brandProfile    BrandProfile    @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  token           String          @unique @default(cuid())
  slug            String?         @unique
  target          ShareLinkTarget
  productId       String?
  collectionId    String?
  customMessage   String?
  password        String?
  lockedCurrency  String?
  expiresAt       DateTime?
  isActive        Boolean         @default(true)
  viewCount       Int             @default(0)
  uniqueVisitors  Int             @default(0)
  signupCount     Int             @default(0)
  orderCount      Int             @default(0)
  revenueInr      Decimal         @default(0) @db.Decimal(12, 2)
  commissionSavedInr Decimal      @default(0) @db.Decimal(10, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  attributedOrders Order[]
  attributedBuyers UserShareLinkAttribution[]

  @@index([brandProfileId])
  @@index([token])
}

model UserShareLinkAttribution {
  id          String    @id @default(cuid())
  userId      String
  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id])
  recordedAt  DateTime  @default(now())

  @@unique([userId, shareLinkId])
}

// ─────────────────────────────────────────────
// REFERRALS
// ─────────────────────────────────────────────

model BuyerReferral {
  id              String       @id @default(cuid())
  referrerUserId  String
  referrer        User         @relation("ReferrerBuyer", fields: [referrerUserId], references: [id])
  referredBrandId String?
  referredBrand   BrandProfile? @relation("ReferredBrand", fields: [referredBrandId], references: [id])
  token           String       @unique @default(cuid())
  rewardIssued    Boolean      @default(false)
  bonusIssued     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([referrerUserId])
  @@index([referredBrandId])
}

// ─────────────────────────────────────────────
// WALLET & CREDITS
// ─────────────────────────────────────────────

model Wallet {
  id          String         @id @default(cuid())
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  balanceInr  Decimal        @default(0) @db.Decimal(10, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  credits     WalletCredit[]
}

model WalletCredit {
  id        String       @id @default(cuid())
  walletId  String
  wallet    Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amountInr Decimal      @db.Decimal(10, 2)
  status    CreditStatus @default(ACTIVE)
  reason    String
  expiresAt DateTime
  createdAt DateTime     @default(now())

  @@index([walletId])
  @@index([status])
}

// ─────────────────────────────────────────────
// PAYOUTS
// ─────────────────────────────────────────────

model Payout {
  id             String       @id @default(cuid())
  brandProfileId String
  brandProfile   BrandProfile @relation(fields: [brandProfileId], references: [id])
  orderId        String       @unique
  order          Order        @relation(fields: [orderId], references: [id])
  grossInr       Decimal      @db.Decimal(12, 2)
  commissionInr  Decimal      @db.Decimal(10, 2)
  processingFeeInr Decimal    @db.Decimal(10, 2) @default(0)
  netInr         Decimal      @db.Decimal(12, 2)
  payoutSpeed    PayoutSpeed  @default(NET_30)
  isPaid         Boolean      @default(false)
  scheduledAt    DateTime?
  paidAt         DateTime?
  paypalBatchId  String?
  createdAt      DateTime     @default(now())

  @@index([brandProfileId])
  @@index([isPaid])
}

// ─────────────────────────────────────────────
// SAVED / FAVOURITES
// ─────────────────────────────────────────────

model SavedProduct {
  id             String       @id @default(cuid())
  buyerProfileId String
  buyer          BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([buyerProfileId, productId])
}

model SavedBrand {
  id             String       @id @default(cuid())
  buyerProfileId String
  buyer          BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  brandProfileId String
  createdAt      DateTime     @default(now())

  @@unique([buyerProfileId, brandProfileId])
}

// ─────────────────────────────────────────────
// FX RATES (audit log)
// ─────────────────────────────────────────────

model FxRateSnapshot {
  id        String   @id @default(cuid())
  rates     Json
  fetchedAt DateTime @default(now())

  @@index([fetchedAt])
}

// ─────────────────────────────────────────────
// MESSENGER
// ─────────────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id])
  recipientId String
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id])
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([senderId])
  @@index([recipientId])
}

// ─────────────────────────────────────────────
// PROMOTED LISTINGS
// ─────────────────────────────────────────────

model PromotedListing {
  id             String       @id @default(cuid())
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  brandProfileId String
  brandProfile   BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  bidAmountInr   Decimal      @db.Decimal(10, 2)
  startsAt       DateTime
  endsAt         DateTime?
  isActive       Boolean      @default(false)
  impressions    Int          @default(0)
  clicks         Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([productId])
  @@index([isActive])
  @@index([brandProfileId])
}

// ─────────────────────────────────────────────
// CRM CONTACTS
// ─────────────────────────────────────────────

model CrmContact {
  id             String       @id @default(cuid())
  brandProfileId String
  brandProfile   BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  name           String?
  email          String
  businessName   String?
  notes          String?
  createdAt      DateTime     @default(now())

  @@unique([brandProfileId, email])
  @@index([brandProfileId])
}

// ─────────────────────────────────────────────
// SHOPIFY INTEGRATION
// ─────────────────────────────────────────────

model ShopifyStore {
  id             String       @id @default(cuid())
  brandProfileId String       @unique
  brandProfile   BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  shopDomain     String       @unique
  accessToken    String
  isActive       Boolean      @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
